SELECT
    transaction_date,
    user_id,
    COUNT(product_id) AS purchase_count
FROM (
    SELECT *,
           ROW_NUMBER() OVER (
               PARTITION BY user_id
               ORDER BY transaction_date DESC
           ) AS rn
    FROM user_transactions
) t
WHERE rn = 1
GROUP BY transaction_date, user_id
ORDER BY transaction_date;
