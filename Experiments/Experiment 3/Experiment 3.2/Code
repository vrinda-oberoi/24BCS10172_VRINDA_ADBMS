-- AGGREGATE FUNCTION -> SUM(),MIN(),MAX(),AVG(),COUNT()

-- (1)
-- COUNT THE NUMBER OF EMPLOYEES IN A EMPLOYEE CITY

-- (I)
SELECT emp_city,COUNT(*) AS CNT
FROM EMPLOYEES
GROUP BY emp_city

-- (II)

SELECT emp_city,COUNT(EMP_ID) AS CNT
FROM EMPLOYEES
GROUP BY emp_city

--(2)- COUNT THE NUMBER OF EMPLOYEES IN A EMPLOYEE CITY AND SORT ON THE BASIS OF 
-- COUNT IN ASC AND  
-- (II) DESC ORDER IF COUNT ARE SAM ETHE SORT ON THE BASIS OF EMP_CITY IN ASCENDING ORDER


-- (I)
SELECT emp_city,COUNT(EMP_ID) AS CNT
FROM EMPLOYEES
GROUP BY emp_city
ORDER BY CNT ASC 

-- (II)
SELECT emp_city,COUNT(EMP_ID) AS CNT
FROM EMPLOYEES
GROUP BY emp_city
ORDER BY CNT DESC , EMP_CITY ASC

-- (3) COUNT THE NUMBER OF EMPLOYEES IN A CITY WHOSE SALARY >=90000

SELECT emp_city, SUM(CASE WHEN EMP_SALARY>=90000 THEN 1 ELSE 0 END) AS CNT
FROM EMPLOYEES
GROUP BY emp_city

-- HAVING CLAUSE

-- FIND THE CITY THAT HAS ONLY ONE EMPLOYEE WHOSE SALARY IS GREATER THEN EQUALS TO 90000
-- AND HAS AT LEAST ONE EMPLOYEE

-- HAVING CLAUSE

SELECT emp_city
FROM EMPLOYEES
GROUP BY emp_city
HAVING  SUM(CASE WHEN EMP_SALARY>=90000 THEN 1 ELSE 0 END)>0


-- FIND THE AVERAGE EMPLOYEE SALARY OF EACH CITY

SELECT emp_city, AVG(EMP_SALARY)::NUMERIC(20,2) AS CNT
FROM EMPLOYEES
GROUP BY emp_city

--  DISTINCT

SELECT DISTINCT EMP_CITY
FROM EMPLOYEES


SELECT COUNT(DISTINCT EMP_CITY) AS CNT
FROM EMPLOYEES

